name: Complete Workflow with Tests, Artifacts, and Deployment

on:
  push:
    branches: [ main, develop ]
  pull_request:
    branches: [ main ]
  workflow_dispatch:

jobs:
  build-test-deploy:
    runs-on: ubuntu-latest
    
    steps:
      # Checkout code
      - name: Checkout code
        uses: actions/checkout@v4

      # Set up your build environment (example: Node.js)
      - name: Set up Node.js
        uses: actions/setup-node@v4
        with:
          node-version: '18'

      # Install dependencies
      - name: Install dependencies
        run: |
          npm install

      # Run tests and generate test results
      - name: Run tests
        run: |
          npm test -- --coverage --reporters=default --reporters=jest-junit
        continue-on-error: true

      # Publish test results
      - name: Publish test results
        uses: EnricoMi/publish-unit-test-results-action@v2
        if: always()
        with:
          files: |
            **/junit.xml
            **/test-results/**/*.xml

      # Build the application
      - name: Build application
        run: |
          npm run build

      # Create artifacts directory
      - name: Prepare artifacts
        run: |
          mkdir -p artifacts
          cp -r build/* artifacts/ || cp -r dist/* artifacts/ || echo "Build output copied"

      # Upload build artifacts
      - name: Upload build artifacts
        uses: actions/upload-artifact@v4
        with:
          name: build-artifacts
          path: |
            artifacts/
            build/
            dist/
          retention-days: 30

      # Simulate deployment (replace with your actual deployment)
      - name: Deploy to staging
        run: |
          echo "Deploying application to staging environment..."
          echo "Deployment URL: https://staging.example.com"
          echo "Deployment completed successfully"
        env:
          DEPLOY_ENV: staging

      # Report deployment status
      - name: Report deployment
        if: success()
        run: |
          echo "::notice::Deployment successful to staging environment"
